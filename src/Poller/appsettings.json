{
  "ConnectionStrings": {
    "Ticks": "Data Source=Data/ticks.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "FeedGrabber": {
    "LaToken": {
      "Name": "LaToken",
      "WebSocketUri": "ws://127.0.0.1:5051/ws",
      "DegreeOfParallelism": 2
    },
    "CoinBase": {
      "Name": "CoinBase",
      "WebSocketUri": "ws://127.0.0.1:5052/ws",
      "DegreeOfParallelism": 2
    }
  },
  "Ingestion": {
    "BatchSize": 100,
    "BatchMaxWait": "00:00:00.200",
    "DeduplicationWindow": "00:00:00.750",
    "ReconnectDelay": "00:00:03",
    "MetricsRateWindow": "00:00:05",
    "MetricsLogInterval": "00:00:03"
  }
}
