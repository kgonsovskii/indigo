{
  "ConnectionStrings": {
    "Ticks": "Data Source=ticks.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "StockGrabber": {
    "LaToken": {
      "Name": "LaToken",
      "WebSocketUri": "ws://127.0.0.1:5051/ws",
      "DegreeOfParallelism": 2
    },
    "CoinBase": {
      "Name": "CoinBase",
      "WebSocketUri": "ws://127.0.0.1:5052/ws",
      "DegreeOfParallelism": 2
    }
  },
  "Ingestion": {
    "BatchSize": 100,
    "BatchMaxWaitMs": 200,
    "DeduplicationWindowMs": 750,
    "ReconnectInitialDelayMs": 500,
    "ReconnectMaxDelayMs": 30000
  }
}
